# Google AI Studio API key (free tier -- for Gemini 2.5 Flash)
GOOGLE_API_KEY=your-google-api-key-here

# MamaGuard agent API key (comma-separated for multiple keys)
MAMAGUARD_API_KEY=dev-key-local

# Public URL where this agent is deployed (Cloud Run URL)
MAMAGUARD_URL=http://localhost:8001

# Prompt Opinion platform base URL
PO_PLATFORM_BASE_URL=https://app.promptopinion.ai

# Actionable SDOH: external resource directory (optional, falls back to curated offline map)
# MAMAGUARD_SDOH_API_URL=https://findhelp.example/api/v1/resources
# MAMAGUARD_SDOH_API_KEY=your-sdoh-api-key-here

# SMART Permission Tickets (optional, disabled by default)
# MAMAGUARD_SMART_TICKETS=true
# MAMAGUARD_SMART_TICKETS_SECRET=your-jwt-signing-secret-here
# MAMAGUARD_SMART_TICKETS_AUDIENCE=https://mamaguard.example.com

# Debug flags
LOG_FULL_PAYLOAD=true
LOG_HOOK_RAW_OBJECTS=false
